# MarkDown++ Environment Variables
#
# Copy this file to .env and modify as needed.
# These variables are used during build and development.

# Set to "1" to build a stable release (disables version hash suffix)
# MARKDOWNPP_IS_STABLE=1

# Set to "1" to exit on unhandled errors (useful for CI/CD)
# MARKDOWNPP_EXIT_ON_ERROR=1

# Node environment (automatically set by build scripts)
# NODE_ENV=development